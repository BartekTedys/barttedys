# Copy this to .env.local and fill in your values
# DO NOT commit .env.local to git

# Modal inference endpoints (set after deploying modal_backend.py)
# Run: modal deploy modal_backend.py
# Then copy the two endpoint URLs printed in the terminal
MODAL_INFER_URL=https://your-modal-app--canopymodel-infer-upload.modal.run
MODAL_INFER_MAP_URL=https://your-modal-app--canopymodel-infer-map.modal.run
